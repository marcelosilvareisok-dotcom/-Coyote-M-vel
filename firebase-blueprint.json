{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (passenger, driver, or admin)",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "role": {
          "type": "string",
          "enum": ["passenger", "driver", "admin"],
          "description": "The role of the user"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "status": {
          "type": "string",
          "enum": ["online", "offline", "busy"],
          "description": "Driver status"
        },
        "vehicleType": {
          "type": "string",
          "enum": ["car", "motorcycle", "none"],
          "description": "Type of vehicle (for drivers)"
        },
        "vehiclePlate": {
          "type": "string",
          "description": "License plate (for drivers)"
        },
        "rating": {
          "type": "number",
          "description": "Average rating"
        },
        "balance": {
          "type": "number",
          "description": "Wallet balance"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "role", "name", "email", "createdAt"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A ride request and its details",
      "type": "object",
      "properties": {
        "passengerId": {
          "type": "string",
          "description": "UID of the passenger"
        },
        "driverId": {
          "type": "string",
          "description": "UID of the driver (null if not accepted yet)"
        },
        "status": {
          "type": "string",
          "enum": ["requested", "accepted", "in_progress", "completed", "cancelled"],
          "description": "Status of the ride"
        },
        "origin": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "destination": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "vehicleType": {
          "type": "string",
          "enum": ["car", "motorcycle"],
          "description": "Requested vehicle type"
        },
        "distance": {
          "type": "number",
          "description": "Estimated distance in km"
        },
        "duration": {
          "type": "number",
          "description": "Estimated duration in minutes"
        },
        "price": {
          "type": "number",
          "description": "Total price for the passenger"
        },
        "driverEarnings": {
          "type": "number",
          "description": "Amount the driver earns"
        },
        "platformFee": {
          "type": "number",
          "description": "Amount the platform earns"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["passengerId", "status", "origin", "destination", "vehicleType", "price", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/rides/{rideId}": {
      "schema": {
        "$ref": "#/entities/Ride"
      },
      "description": "Stores ride requests and history"
    }
  }
}
